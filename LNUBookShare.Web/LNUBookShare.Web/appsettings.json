{
  "ConnectionStrings": {
    "DefaultConnection": "Вставте_рядок_підключення_через_Secret_Manager"
  },
  "EmailSettings": {
    "SenderEmail": "apuhlij66@gmail.com",
    "SenderPassword": "Вставте_пароль_через_Secret_Manager",
    "SmtpServer": "smtp.gmail.com",
    "Port": 587
  },
  "CloudinarySettings": {
    "CloudName": "Вставте_CloudName_через_Secret_Manager",
    "ApiKey": "Вставте_ApiKey_через_Secret_Manager",
    "ApiSecret": "Вставте_ApiSecret_через_Secret_Manager"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "PhotoSettings": {
    "MaxFileSizeBytes": 5242880,
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png" ]
  },
  "ReservationSettings": {
    "MaxQueueSize": 5
  },
  "ReviewSettings": {
    "MinRating": 1,
    "MaxRating": 5,
    "MaxCommentLength": 1000
  },
  "ChatSettings": {
    "MaxMessageLength": 1000
  },
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [ "Serilog.Sinks.Seq" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Seq",
        "Args": { "serverUrl": "http://localhost:5341" }
      },
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}