@model IEnumerable<LNUBookShare.Domain.Models.AdminBookDto>

@{
    ViewData["Title"] = "Керування оголошеннями";
}

<div class="container mt-5">
    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger shadow-sm">
            <i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.Error
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="px-4">Назва книги</th>
                            <th>Автор</th>
                            <th>Власник</th>
                            <th>Email власника</th>
                            <th>Статус</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var book in Model)
                        {
                            <tr>
                                <td class="px-4 fw-bold text-primary">@book.Title</td>
                                <td>@book.Author</td>
                                <td>@book.OwnerName</td>
                                <td>@book.OwnerEmail</td>
                                <td><span class="badge bg-secondary">@book.Status</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white text-center py-3">
            <small class="text-muted">Всього оголошень: @Model.Count()</small>
        </div>
    </div>
</div>