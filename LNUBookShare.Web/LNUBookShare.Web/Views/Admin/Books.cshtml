@model IEnumerable<LNUBookShare.Domain.Models.AdminBookDto>

@{
    ViewData["Title"] = "Керування оголошеннями";
    var currentQuery = ViewBag.CurrentQuery as string;
    var currentSearchBy = ViewBag.CurrentSearchBy as string ?? "title";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">Керування оголошеннями</h2>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger shadow-sm mb-4">
            <i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.Error
        </div>
    }

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body bg-light">
            <form asp-action="AdminSearchBooks" method="get" class="row g-2">
                <div class="col-md-3">
                    <select name="searchBy" class="form-select border-0 shadow-sm">
                        <!option value="title" @(currentSearchBy == "title" ? "selected" : "")>Назва книги</!option>
                        <!option value="author" @(currentSearchBy == "author" ? "selected" : "")>Автор</!option>
                        <!option value="isbn" @(currentSearchBy == "isbn" ? "selected" : "")>ISBN</!option>
                        <!option value="owner" @(currentSearchBy == "owner" ? "selected" : "")>Власник</!option>
                    </select>
                </div>
                <div class="col-md-7">
                    <div class="input-group shadow-sm">
                        <input type="text"
                               name="query"
                               class="form-control border-0"
                               placeholder="Введіть текст для пошуку..."
                               value="@currentQuery" />
                        <button class="btn btn-primary px-4" type="submit">
                            <i class="bi bi-search"></i> Пошук
                        </button>
                    </div>
                </div>
                <div class="col-md-2">
                    <a asp-action="Books" class="btn btn-outline-secondary w-100 shadow-sm">Скинути</a>
                </div>
            </form>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(currentQuery))
    {
        <div class="mb-3">
            <span class="text-muted small">Знайдено результатів для: <strong>"@currentQuery"</strong></span>
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="px-4">Назва книги</th>
                            <th>Автор</th>
                            <th>Власник</th>
                            <th>Isbn</th>
                            <th>Email власника</th>
                            <th>Статус</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <i class="bi bi-search d-block fs-1 mb-2"></i>
                                    За вашим запитом нічого не знайдено.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var book in Model)
                            {
                                <tr>
                                    <td class="px-4 fw-bold text-primary">@book.Title</td>
                                    <td>@book.Author</td>
                                    <td>@book.OwnerName</td>
                                    <td>@book.Isbn</td>
                                    <td>@book.OwnerEmail</td>
                                    <td>                                        
                                        @{
                                            var badgeClass = book.Status?.ToLower() == "active" ? "bg-success" : "bg-secondary";
                                        }
                                        <span class="badge @badgeClass">@book.Status</span>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card-footer bg-white text-center py-3">
            <small class="text-muted">Всього в списку: @Model.Count()</small>
        </div>
    </div>
</div>