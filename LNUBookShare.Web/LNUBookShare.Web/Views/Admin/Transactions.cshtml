@using LNUBookShare.Domain.Entities
@model IEnumerable<RentalTransaction>

@{
    ViewData["Title"] = "Керування транзакціями";
    var currentQuery = ViewBag.CurrentQuery as string;
    var currentSearchBy = ViewBag.CurrentSearchBy as string ?? "book";
    var currentSortBy = ViewBag.CurrentSortBy as string ?? "date_asc";
    var currentStatusFilter = ViewBag.CurrentStatusFilter as string ?? "active";
    var currentTermFilter = ViewBag.CurrentTermFilter as string ?? "all";
}

@section Styles {
    <environment include="Development">
        <link rel="stylesheet" href="~/css/modules/admin.css" asp-append-version="true" />
    </environment>
}

<div class="container mt-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-pill mb-4"><i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-pill mb-4"><i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]</div>
    }
    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger alert-pill mb-4"><i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewBag.Error</div>
    }

    <form asp-action="Transactions" method="get" class="mb-4">
        <div class="row">
            <div class="col-lg-9">
                <div class="d-flex gap-2 mb-4">
                    <select name="searchBy" class="form-select border-secondary-subtle admin-search-select" onchange="this.form.submit()">
                        <option value="book" selected="@(currentSearchBy == "book")">Назва книги</option>
                        <option value="owner" selected="@(currentSearchBy == "owner")">Власник</option>
                        <option value="borrower" selected="@(currentSearchBy == "borrower")">Орендар</option>
                    </select>

                    <div class="position-relative flex-grow-1" style="min-width: 0;">
                        <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted search-icon-pos"></i>
                        <input type="text" name="query" value="@currentQuery" class="form-control border-secondary-subtle ps-5 py-2 admin-search-input" placeholder="Введіть текст для пошуку..." autocomplete="off" />
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(currentQuery))
                {
                    <div class="mb-3"><span class="text-muted small">Знайдено результатів для: <strong>"@currentQuery"</strong></span></div>
                }

                <div class="card admin-table-card">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="px-4">Назва книги</th>
                                        <th>Власник</th>
                                        <th>Орендар</th>
                                        <th>Дата видачі</th>
                                        <th>Очікуване повернення</th>
                                        <th class="text-center px-4">Статус</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!Model.Any())
                                    {
                                        <tr><td colspan="6" class="text-center py-5 text-muted"><i class="bi bi-arrow-left-right d-block fs-1 mb-2"></i>Транзакцій не знайдено.</td></tr>
                                    }
                                    else
                                    {
                                        @foreach (var t in Model)
                                        {
                                            bool isOverdue = t.Status == "active" && t.ExpectedReturnDate < DateTime.UtcNow;
                                            <tr class="@(isOverdue ? "table-danger" : "")">
                                                <td class="px-4" style="max-width: 200px;"><a asp-controller="Catalog" asp-action="Details" asp-route-id="@t.BookId" class="text-decoration-none fw-bold">@(t.Book?.Title ?? "Невідомо")</a></td>
                                                <td><a asp-controller="OtherProfile" asp-action="Index" asp-route-userId="@t.Owner?.Id" class="text-decoration-none fw-bold d-block">@(t.Owner?.FirstName ?? "")</a><small class="text-muted">@t.Owner?.Email</small></td>
                                                <td><a asp-controller="OtherProfile" asp-action="Index" asp-route-userId="@t.Borrower?.Id" class="text-decoration-none fw-bold d-block">@(t.Borrower?.FirstName ?? "")</a><small class="text-muted">@t.Borrower?.Email</small></td>
                                                <td>@t.IssueDate.ToString("dd.MM.yyyy")</td>
                                                <td><span class="@(isOverdue ? "text-danger fw-bold" : "")">@t.ExpectedReturnDate.ToString("dd.MM.yyyy")</span></td>
                                                <td class="text-center px-4"><span class="badge @(t.Status == "returned" ? "bg-secondary" : "bg-success") rounded-pill">@(t.Status == "returned" ? "Повернуто" : "Активна")</span></td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="card-footer bg-white text-center py-3"><small class="text-muted">Всього транзакцій: @Model.Count()</small></div>
                </div>
            </div>

            <div class="col-lg-3">
                <div class="card admin-filter-card">
                    <div class="card-header bg-white border-bottom-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                        <span class="fw-bold text-dark"><i class="bi bi-funnel me-1 text-muted"></i> Фільтри</span>
                        <a asp-action="Transactions" class="btn btn-light btn-sm">Скинути</a>
                    </div>
                    <div class="card-body">
                        <h6 class="text-muted small fw-bold text-uppercase mb-3">Статус оренди</h6>
                        <div class="mb-4">
                            <div class="form-check mb-2"><input class="form-check-input" type="radio" name="statusFilter" value="active" checked="@(currentStatusFilter == "active")" onchange="this.form.submit()"><label class="form-check-label">Активні</label></div>
                            <div class="form-check mb-2"><input class="form-check-input" type="radio" name="statusFilter" value="all" checked="@(currentStatusFilter == "all")" onchange="this.form.submit()"><label class="form-check-label">Всі</label></div>
                            <div class="form-check mb-2"><input class="form-check-input" type="radio" name="statusFilter" value="returned" checked="@(currentStatusFilter == "returned")" onchange="this.form.submit()"><label class="form-check-label">Повернуті</label></div>
                        </div>
                        <hr class="text-secondary-subtle my-3">
                        <h6 class="text-muted small fw-bold text-uppercase mb-3">Термін</h6>
                        <div class="mb-3">
                            <div class="form-check mb-2"><input class="form-check-input" type="radio" name="termFilter" value="all" checked="@(currentTermFilter == "all")" onchange="this.form.submit()"><label class="form-check-label">Всі</label></div>
                            <div class="form-check mb-2"><input class="form-check-input" type="radio" name="termFilter" value="overdue" checked="@(currentTermFilter == "overdue")" onchange="this.form.submit()"><label class="form-check-label">Прострочені</label></div>
                        </div>
                        <hr class="text-secondary-subtle my-3">
                        <h6 class="text-muted small fw-bold text-uppercase mb-3">Сортування</h6>
                        <div>
                            <div class="form-check mb-2"><input class="form-check-input" type="radio" name="sortBy" value="date_asc" checked="@(currentSortBy == "date_asc")" onchange="this.form.submit()"><label class="form-check-label small">Датою (найближчі)</label></div>
                            <div class="form-check mb-2"><input class="form-check-input" type="radio" name="sortBy" value="date_desc" checked="@(currentSortBy == "date_desc")" onchange="this.form.submit()"><label class="form-check-label small">Датою (найдальші)</label></div>
                            <div class="form-check mb-2"><input class="form-check-input" type="radio" name="sortBy" value="created" checked="@(currentSortBy == "created")" onchange="this.form.submit()"><label class="form-check-label small">Видачею (нові)</label></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>