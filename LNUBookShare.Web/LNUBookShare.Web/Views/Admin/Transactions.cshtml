@using LNUBookShare.Domain.Entities
@model IEnumerable<RentalTransaction>

@{
    ViewData["Title"] = "Керування транзакціями";
    var currentQuery = ViewBag.CurrentQuery as string;
    var currentSearchBy = ViewBag.CurrentSearchBy as string ?? "book";
    var currentSortBy = ViewBag.CurrentSortBy as string ?? "date_asc";
    var currentStatusFilter = ViewBag.CurrentStatusFilter as string ?? "active";
}

<div class="container mt-5">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@ViewBag.Error
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form asp-action="Transactions" method="get" class="mb-4">
        <div class="row">

            <div class="col-lg-9">
                
                <div class="d-flex gap-2 mb-4">
                    <select name="searchBy" class="form-select border border-secondary-subtle shadow-sm" style="width: 160px; border-radius: 8px;" onchange="this.form.submit()">
                        <option value="book" selected="@(currentSearchBy == "book")">Назва книги</option>
                        <option value="owner" selected="@(currentSearchBy == "owner")">Власник</option>
                        <option value="borrower" selected="@(currentSearchBy == "borrower")">Орендар</option>
                    </select>

                    <div class="position-relative flex-grow-1" style="min-width: 0;">
                        <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted" style="z-index: 5;"></i>
                        <input type="text" name="query" value="@currentQuery" class="form-control border border-secondary-subtle ps-5 py-2 shadow-sm" style="border-radius: 8px; width: 100%;" placeholder="Введіть текст для пошуку..." autocomplete="off" />
                    </div>
    
                    <button type="submit" class="d-none"></button>
                </div>

                @if (!string.IsNullOrEmpty(currentQuery))
                {
                    <div class="mb-3">
                        <span class="text-muted small">Знайдено результатів для: <strong>"@currentQuery"</strong></span>
                    </div>
                }

                <div class="card shadow-sm border-0">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="px-4">Назва книги</th>
                                        <th>Власник</th>
                                        <th>Орендар (Хто взяв)</th>
                                        <th>Дата видачі</th>
                                        <th>Очікуване повернення</th>
                                        <th class="text-center px-4">Статус</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!Model.Any())
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center py-5 text-muted">
                                                <i class="bi bi-arrow-left-right d-block fs-1 mb-2"></i>
                                                Транзакцій не знайдено.
                                            </td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var transaction in Model)
                                        {
                                            bool isOverdue = transaction.Status == "active" && transaction.ExpectedReturnDate < DateTime.UtcNow;
                                            
                                            <tr class="@(isOverdue ? "table-danger" : "")">
                                                <td class="px-4 fw-medium text-dark" style="max-width: 200px;">
                                                    @(transaction.Book?.Title ?? "Невідомо")
                                                </td>
                                                <td>
                                                    @if (transaction.Owner != null)
                                                    {
                                                        <span class="d-block">@transaction.Owner.FirstName @transaction.Owner.LastName</span>
                                                        <small class="text-muted" style="font-size: 0.75rem;">@transaction.Owner.Email</small>
                                                    }
                                                </td>
                                                <td>
                                                    @if (transaction.Borrower != null)
                                                    {
                                                        <span class="d-block">@transaction.Borrower.FirstName @transaction.Borrower.LastName</span>
                                                        <small class="text-muted" style="font-size: 0.75rem;">@transaction.Borrower.Email</small>
                                                    }
                                                </td>
                                                <td>@transaction.IssueDate.ToString("dd.MM.yyyy")</td>
                                                <td>
                                                    <span class="@(isOverdue ? "text-danger fw-bold" : "")">
                                                        @transaction.ExpectedReturnDate.ToString("dd.MM.yyyy")
                                                    </span>
                                                    @if (isOverdue)
                                                    {
                                                        <i class="bi bi-exclamation-circle-fill text-danger ms-1" title="Прострочено!"></i>
                                                    }
                                                </td>
                                                <td class="text-center px-4">
                                                    @if (transaction.Status == "returned")
                                                    {
                                                        <span class="badge bg-secondary rounded-pill">Повернуто</span>
                                                    }
                                                    else if (isOverdue || transaction.Status == "overdue")
                                                    {
                                                        <span class="badge bg-danger rounded-pill">Прострочено</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-success rounded-pill">Активна</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                    <div class="card-footer bg-white text-center py-3">
                        <small class="text-muted">Всього транзакцій у списку: @Model.Count()</small>
                    </div>
                </div>
            </div>

            <div class="col-lg-3">
                <div class="card shadow-sm border-0" style="border-radius: 8px;">
                    <div class="card-header bg-white border-bottom-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                        <span class="fw-bold text-dark"><i class="bi bi-funnel me-1 text-muted"></i> Фільтри</span>
                        <a asp-action="Transactions" class="btn btn-link btn-sm text-muted text-decoration-none p-0">Скинути</a>
                    </div>
                    
                    <div class="card-body">
                        
                        <h6 class="text-muted small fw-bold text-uppercase mb-3">Статус оренди</h6>
                        <div class="mb-4">
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="statusFilter" id="statusActive" value="active" checked="@(currentStatusFilter == "active")" onchange="this.form.submit()">
                                <label class="form-check-label text-dark" for="statusActive">Тільки активні (в процесі)</label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="statusFilter" id="statusAll" value="all" checked="@(currentStatusFilter == "all")" onchange="this.form.submit()">
                                <label class="form-check-label text-dark" for="statusAll">Всі транзакції (історія)</label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="statusFilter" id="statusReturned" value="returned" checked="@(currentStatusFilter == "returned")" onchange="this.form.submit()">
                                <label class="form-check-label text-dark" for="statusReturned">Тільки повернуті</label>
                            </div>
                        </div>

                        <hr class="text-secondary-subtle my-3">

                        <h6 class="text-muted small fw-bold text-uppercase mb-3">Сортування</h6>
                        <div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="sortBy" id="sortDateAsc" value="date_asc" checked="@(currentSortBy == "date_asc")" onchange="this.form.submit()">
                                <label class="form-check-label text-dark" for="sortDateAsc">За датою повернення (спершу найближчі)</label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="sortBy" id="sortDateDesc" value="date_desc" checked="@(currentSortBy == "date_desc")" onchange="this.form.submit()">
                                <label class="form-check-label text-dark" for="sortDateDesc">За датою повернення (спершу найдальші)</label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="sortBy" id="sortCreated" value="created" checked="@(currentSortBy == "created")" onchange="this.form.submit()">
                                <label class="form-check-label text-dark" for="sortCreated">За датою видачі (нові угоди)</label>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

        </div>
    </form>
</div>