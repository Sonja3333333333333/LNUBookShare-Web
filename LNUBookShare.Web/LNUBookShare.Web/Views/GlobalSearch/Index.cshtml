@model List<LNUBookShare.Application.DTOs.GlobalBookDto>

@{
    ViewData["Title"] = "Глобальний пошук книг";
    // Дістаємо поточний запит з URL, щоб він залишався в полі після пошуку
    var currentQuery = Context.Request.Query["query"].ToString();
}

@section Styles {
    <environment include="Development">
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/modules/bookCard.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/modules/filters.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/modules/leaderboard.css" asp-append-version="true" />
    </environment>
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="fw-bold text-dark">Глобальний пошук</h1>
        <p class="text-muted">Не знайшли книгу в ЛНУ? Спробуйте знайти її цифрову версію у світовій бібліотеці.</p>
    </div>

    @* --- ОНОВЛЕНА ФОРМА ПОШУКУ --- *@
    <div class="row justify-content-center mb-5">
        <div class="col-md-8">
            <form asp-controller="GlobalSearch" asp-action="Index" method="get">
                <div class="position-relative w-100">
                    <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted" style="z-index: 5;"></i>
                    <input type="text" name="query" value="@currentQuery"
                           class="form-control ps-5 py-2"
                           placeholder="Введіть назву книги або автора..."
                           autocomplete="off" required />
                    
                    <button type="submit" class="d-none"></button>
                </div>
            </form>
        </div>
    </div>

    <div class="row">
        @if (Model != null && Model.Any())
        {
            foreach (var book in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm border-0 bg-white book-item-card" style="overflow: hidden;">
                        <div class="row g-0 h-100">
                            <div class="col-4 bg-light d-flex align-items-center justify-content-center p-0" style="min-height: 150px; border-right: 1px solid #eaeaea;">
                                @if (!string.IsNullOrEmpty(book.CoverUrl))
                                {
                                    <img src="@book.CoverUrl" alt="Обкладинка" class="img-fluid h-100 w-100" style="object-fit: cover;">
                                }
                                else
                                {
                                    <i class="bi bi-journal-text text-secondary" style="font-size: 3rem;"></i>
                                }
                            </div>
                            <div class="col-8">
                                <div class="card-body d-flex flex-column h-100 p-3">
                                    <h6 class="card-title fw-bold text-dark mb-1 text-truncate-2" title="@book.Title">
                                        @book.Title
                                    </h6>
                                    <p class="text-muted small mb-3">@book.Author</p>
                                    
                                    @* --- НАШІ ОНОВЛЕНІ КНОПКИ --- *@
                                    <div class="mt-auto d-grid gap-2">
                                        @if (book.HasFullText)
                                        {
                                            @* Використовуємо наш btn-primary *@
                                            <a href="@book.OpenLibraryUrl" target="_blank" class="btn btn-primary btn-sm">
                                                <i class="bi bi-book-half me-1"></i> Читати
                                            </a>
                                        }
                                        else
                                        {
                                            @* Використовуємо наш btn-light *@
                                            <a href="@book.OpenLibraryUrl" target="_blank" class="btn btn-light btn-sm">
                                                <i class="bi bi-info-circle me-1"></i> Деталі
                                            </a>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else if (Context.Request.Query.ContainsKey("query"))
        {
            <div class="text-center py-5 w-100">
                <div class="mb-3">
                    <i class="bi bi-cloud-slash text-secondary-subtle" style="font-size: 5rem;"></i>
                </div>
                <h4 class="text-secondary fw-bold">Нічого не знайдено</h4>
                <p class="text-muted">Спробуйте змінити запит або перевірити правопис.</p>
            </div>
        }
    </div>
</div>