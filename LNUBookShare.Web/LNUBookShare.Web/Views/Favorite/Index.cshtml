@using LNUBookShare.Domain.Entities
@using LNUBookShare.Domain.Models
@model IEnumerable<Book>

@{
    ViewData["Title"] = "Уподобані книги";

    var queryParams = ViewBag.QueryParameters as FavoriteBooksQueryParameters ?? new FavoriteBooksQueryParameters();
    string currentSort = queryParams.SortBy?.ToLower() ?? "title";
    string currentStatus = queryParams.Status?.ToLower() ?? "";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-12">

            @* Виведення помилки для негативного сценарію *@
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger shadow-sm mb-4" style="border-radius: 8px;">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
                </div>
            }

            @* ФОРМА СОРТУВАННЯ ТА ФІЛЬТРАЦІЇ (Ідентична головному вікну) *@
            <form asp-controller="Favorite" asp-action="Index" method="get" class="mb-4">
                <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom border-secondary-subtle">
                    
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted" style="font-size: 0.9rem;">Сортувати за:</span>
                        <select name="SortBy" class="form-select form-select-sm border-0 bg-light fw-medium" style="width: 130px; cursor: pointer;" onchange="this.form.submit()">
                            <option value="title" selected="@(currentSort == "title")">Назва</option>
                            <option value="author" selected="@(currentSort == "author")">Автор</option>
                            <option value="year" selected="@(currentSort == "year")">Рік видання</option>
                        </select>
                    </div>

                    <div class="d-flex gap-3 align-items-center">
                        <div class="form-check custom-radio">
                            <input class="form-check-input" type="radio" name="Status" id="statusAll" value="" checked="@(string.IsNullOrEmpty(currentStatus))" onchange="this.form.submit()">
                            <label class="form-check-label text-muted" for="statusAll" style="font-size: 0.9rem;">Всі</label>
                        </div>
                        <div class="form-check custom-radio">
                            <input class="form-check-input" type="radio" name="Status" id="statusAvail" value="available" checked="@(currentStatus == "available")" onchange="this.form.submit()">
                            <label class="form-check-label text-muted" for="statusAvail" style="font-size: 0.9rem;">Доступно</label>
                        </div>
                        <div class="form-check custom-radio">
                            <input class="form-check-input" type="radio" name="Status" id="statusBorrowed" value="borrowed" checked="@(currentStatus == "borrowed")" onchange="this.form.submit()">
                            <label class="form-check-label text-muted" for="statusBorrowed" style="font-size: 0.9rem;">Видано</label>
                        </div>
                        <div class="form-check custom-radio">
                            <input class="form-check-input" type="radio" name="Status" id="statusReserved" value="reserved" checked="@(currentStatus == "reserved")" onchange="this.form.submit()">
                            <label class="form-check-label text-muted" for="statusReserved" style="font-size: 0.9rem;">Заброньовано</label>
                        </div>
                    </div>

                </div>
            </form>

            <div class="book-list">
                @if (Model != null && Model.Any())
                {
                    @foreach (var book in Model)
                    {
                        <div class="card mb-3 shadow-sm border-0 bg-white" style="border-radius: 12px; border: 1px solid #e0e0e0 !important; overflow: hidden;">
                            <div class="row g-0 align-items-center">

                                <div class="col-md-3 text-center bg-light d-flex align-items-center justify-content-center p-0" style="height: 160px; border-right: 1px solid #e0e0e0; overflow: hidden;">
                                    @if (book.Cover != null && !string.IsNullOrEmpty(book.Cover.ImagePath))
                                    {
                                        <img src="@book.Cover.ImagePath"
                                             alt="Обкладинка"
                                             style="height: 100%; width: 100%; object-fit: cover; object-position: center;" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-image text-secondary" style="font-size: 3rem;"></i>
                                    }
                                </div>

                                <div class="col-md-9 position-relative">
                                    <div class="card-body">

                                        <form asp-controller="Favorite" asp-action="Toggle" method="post" class="position-absolute top-0 end-0 mt-2 me-2">
                                            <input type="hidden" name="bookId" value="@book.BookId" />
                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                                            <button type="submit" class="btn btn-link p-0 text-decoration-none" title="Видалити з уподобань">
                                                <i class="bi bi-heart-fill fs-4 text-danger"></i>
                                            </button>
                                        </form>

                                        <h5 class="card-title pe-5 mb-3">
                                            <a asp-controller="Catalog" asp-action="Details" asp-route-id="@book.BookId" class="text-decoration-none text-dark fw-bold hover-primary">
                                                @book.Title
                                            </a>
                                        </h5>

                                        <p class="card-text mb-1 text-muted" style="font-size: 0.9rem;">
                                            Автор: <span class="text-dark">@book.Author</span>
                                        </p>

                                        <p class="card-text mb-1 text-muted" style="font-size: 0.9rem;">
                                            Власник: <span class="text-dark">@(book.Owner?.FirstName ?? "Невідомо") @(book.Owner?.LastName ?? "")</span>
                                        </p>

                                        <p class="card-text mb-1 text-muted" style="font-size: 0.9rem;">
                                            Статус: <span class="text-dark">
                                            @(book.Status switch
                                            {
                                                "available" => "Доступно",
                                                "reserved" => "Заброньовано",
                                                "borrowed" => "Видано",
                                                _ => book.Status
                                            })
                                        </span>
                                    </p>

                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
                else
            {
                <div class="text-center text-muted mt-5">
                    <i class="bi bi-journal-x" style="font-size: 4rem; color: #ccc;"></i>
                    <h5 class="mt-3">За вашим запитом книг не знайдено.</h5>
                    <p>Спробуйте змінити фільтри або</p>
                    <a asp-controller="Catalog" asp-action="Search" class="btn btn-outline-primary mt-2">Перейти до каталогу</a>
                </div>
            }
        </div>

        <div class="mt-4 text-center">
        </div>

    </div>
</div>
</div>