@using LNUBookShare.Domain.Entities
@using LNUBookShare.Domain.Models
@model IEnumerable<Book>

@{
    ViewData["Title"] = "Уподобані книги";

    var queryParams = ViewBag.QueryParameters as FavoriteBooksQueryParameters ?? new FavoriteBooksQueryParameters();
    string currentSort = queryParams.SortBy?.ToLower() ?? "title";
    string currentStatus = queryParams.Status?.ToLower() ?? "";
}

@section Styles {
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/bookCard.css" asp-append-version="true" />
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-12">

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger shadow-sm mb-4 custom-alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
                </div>
            }

            @* --- ФОРМА СОРТУВАННЯ ТА ФІЛЬТРАЦІЇ --- *@
            <form asp-controller="Favorite" asp-action="Index" method="get" class="mb-4">
                <div class="d-flex justify-content-between align-items-center mb-3 pb-2 border-bottom border-secondary-subtle">
                    
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted small">Сортувати за:</span>
                        @* Додано клас .sort-dropdown *@
                        <select name="SortBy" class="form-select form-select-sm sort-dropdown fw-medium" onchange="this.form.submit()">
                            <option value="title" selected="@(currentSort == "title")">Назва</option>
                            <option value="author" selected="@(currentSort == "author")">Автор</option>
                            <option value="year" selected="@(currentSort == "year")">Рік видання</option>
                        </select>
                    </div>

                    <div class="d-flex gap-3 align-items-center">
                        @foreach (var status in new[] { ("", "Всі"), ("available", "Доступно"), ("borrowed", "Видано"), ("reserved", "Заброньовано") })
                        {
                            <div class="form-check custom-radio">
                                <input class="form-check-input" type="radio" name="Status" id="status_@status.Item1"
                                       value="@status.Item1" checked="@(currentStatus == status.Item1)" onchange="this.form.submit()">
                                <label class="form-check-label text-muted small" for="status_@status.Item1">@status.Item2</label>
                            </div>
                        }
                    </div>
                </div>
            </form>

            @* --- СПИСОК КНИГ --- *@
            <div class="book-list">
                @if (Model != null && Model.Any())
                {
                    @foreach (var book in Model)
                    {
                        <div class="card mb-3 shadow-sm book-item-card">
                            <div class="row g-0 align-items-center">

                                @* Додано клас .book-img-container *@
                                <div class="col-md-3 book-img-container">
                                    @if (book.Cover != null && !string.IsNullOrEmpty(book.Cover.ImagePath))
                                    {
                                        @* Додано клас .book-main-img *@
                                        <img src="@book.Cover.ImagePath" alt="Обкладинка" class="book-main-img" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-image text-secondary" style="font-size: 3rem;"></i>
                                    }
                                </div>

                                <div class="col-md-9 position-relative">
                                    <div class="card-body">

                                        @* Додано клас .fav-btn-pos для позиціонування кнопки-сердечка *@
                                        <form asp-controller="Favorite" asp-action="Toggle" method="post" class="fav-btn-pos">
                                            <input type="hidden" name="bookId" value="@book.BookId" />
                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                                            <button type="submit" class="btn btn-link p-0 text-decoration-none" title="Видалити з уподобань">
                                                <i class="bi bi-heart-fill fs-4 text-danger"></i>
                                            </button>
                                        </form>

                                        <h5 class="card-title">
                                            @* Додано клас .book-link *@
                                            <a asp-controller="Catalog" asp-action="Details" asp-route-id="@book.BookId"
                                               class="book-link">
                                                @book.Title
                                            </a>
                                        </h5>

                                        <p class="card-text mb-1 text-muted small">
                                            Автор: <span class="text-dark">@book.Author</span>
                                        </p>

                                        <p class="card-text mb-1 text-muted small">
                                            Власник:
                                            @* Додано клас .owner-link *@
                                            <a asp-controller="OtherProfile" asp-action="Index" asp-route-userId="@book.Owner?.Id"
                                               class="owner-link">
                                                @(book.Owner?.FirstName ?? "Невідомо") @(book.Owner?.LastName ?? "")
                                            </a>
                                        </p>

                                        <p class="card-text mb-1 text-muted small">
                                            Статус: 
                                            @* Додано класи .status-label та кольорові статуси *@
                                            <span class="status-label @(book.Status switch {
                                                "available" => "status-available",
                                                "reserved" => "status-reserved",
                                                "borrowed" => "status-borrowed",
                                                _ => ""
                                            })">
                                                @(book.Status switch
                                                {
                                                    "available" => "Доступно",
                                                    "reserved" => "Заброньовано",
                                                    "borrowed" => "Видано",
                                                    _ => book.Status
                                                })
                                            </span>
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="mt-4 text-center">
                        <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#clearModal">
                            Очистити вподобане
                        </button>
                    </div>
                }
                else
                {
                    <div class="empty-state text-center mt-5">
                        <i class="bi bi-journal-x"></i>
                        <h5 class="mt-3">Упс, тут поки порожньо!</h5>
                        <p>Спробуйте змінити фільтри або додайте нові книги з каталогу.</p>
                        <a asp-controller="Catalog" asp-action="Search" class="btn btn-primary mt-2">Перейти до каталогу</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* МОДАЛЬНЕ ВІКНО *@
<div class="modal fade" id="clearModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">Очистити список?</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center p-4">
                <i class="bi bi-trash3 text-danger mb-3 d-block" style="font-size: 2.5rem;"></i>
                <p>Ви впевнені, що хочете видалити всі книги зі списку уподобань?</p>
            </div>
            <div class="modal-footer border-0 justify-content-center pb-4">
                <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Скасувати</button>
                <form asp-controller="Favorite" asp-action="ClearAll" method="post">
                    <button type="submit" class="btn btn-danger px-4 shadow-sm">Так, очистити</button>
                </form>
            </div>
        </div>
    </div>
</div>