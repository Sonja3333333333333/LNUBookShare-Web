@using LNUBookShare.Domain.Entities
@using LNUBookShare.Domain.Models
@model IEnumerable<Book>

@{
    ViewData["Title"] = "Уподобані книги";

    var queryParams = ViewBag.QueryParameters as FavoriteBooksQueryParameters ?? new FavoriteBooksQueryParameters();
    string currentSort = queryParams.SortBy?.ToLower() ?? "title";
    string currentStatus = queryParams.Status?.ToLower() ?? "";
}

@section Styles {
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/bookCard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/filters.css" asp-append-version="true" />
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-12">

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-pill shadow-sm mb-4">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
                </div>
            }

            <form asp-controller="Favorite" asp-action="Index" method="get" class="mb-2">
                <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-3">
                    
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted small">Сортувати:</span>
                        <select name="SortBy" class="form-select form-select-sm sort-dropdown" onchange="this.form.submit()">
                            <option value="title" selected="@(currentSort == "title")">Назва</option>
                            <option value="author" selected="@(currentSort == "author")">Автор</option>
                            <option value="year" selected="@(currentSort == "year")">Рік видання</option>
                        </select>
                    </div>

                    <div class="d-flex gap-3 align-items-center status-filters">
                        @foreach (var status in new[] { ("", "Всі"), ("available", "Доступно"), ("borrowed", "Видано"), ("reserved", "Заброньовано") })
                        {
                            <div class="form-check custom-radio">
                                <input class="form-check-input" type="radio" name="Status" id="status_@status.Item1"
                                       value="@status.Item1" checked="@(currentStatus == status.Item1)" onchange="this.form.submit()">
                                <label class="form-check-label" for="status_@status.Item1">@status.Item2</label>
                            </div>
                        }
                    </div>
                </div>
            </form>

            <div class="book-list">
                @if (Model != null && Model.Any())
                {
                    @foreach (var book in Model)
                    {
                        <div class="card mb-3 shadow-sm book-item-card">
                            <div class="row g-0 align-items-center">

                                <div class="col-md-3 book-img-container">
                                    @if (book.Cover != null && !string.IsNullOrEmpty(book.Cover.ImagePath))
                                    {
                                        <img src="@book.Cover.ImagePath" alt="Обкладинка" class="book-main-img" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-image text-secondary display-6"></i>
                                    }
                                </div>

                                <div class="col-md-9 position-relative">
                                    <div class="card-body">

                                        @* Кнопка-сердечко *@
                                        <form asp-controller="Favorite" asp-action="Toggle" method="post" class="fav-btn-pos">
                                            <input type="hidden" name="bookId" value="@book.BookId" />
                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />

                                            <button type="submit" class="btn btn-link p-0 text-decoration-none" title="Видалити з уподобань">
                                                <i class="bi bi-heart-fill fs-4 text-danger"></i>
                                            </button>
                                        </form>

                                        <h5 class="card-title pe-5">
                                            <a asp-controller="Catalog" asp-action="Details" asp-route-id="@book.BookId" class="book-link">
                                                @book.Title
                                            </a>
                                        </h5>

                                        <p class="mb-1 small">Автор: <strong>@book.Author</strong></p>

                                        <p class="mb-1 small">
                                            Власник:
                                            <a asp-controller="OtherProfile" asp-action="Index" asp-route-userId="@book.Owner?.Id" class="owner-link">
                                                @(book.Owner?.FirstName ?? "Невідомо") @(book.Owner?.LastName ?? "")
                                            </a>
                                        </p>

                                        <div class="mt-2">
                                            <span class="status-label @(book.Status switch {
                                                "available" => "status-available",
                                                "reserved" => "status-reserved",
                                                "borrowed" => "status-borrowed",
                                                _ => ""
                                            })">
                                                @(book.Status switch
                                                {
                                                    "available" => "Доступно",
                                                    "reserved" => "Заброньовано",
                                                    "borrowed" => "Видано",
                                                    _ => book.Status
                                                })
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    <div class="mt-4 text-center">
                        <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#clearModal">
                            Очистити вподобане
                        </button>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-journal-x fs-1 d-block mb-3 opacity-25"></i>
                        <h5>Упс, тут поки порожньо!</h5>
                        <p>Додайте книги, які вам сподобалися, з каталогу.</p>
                        <a asp-controller="Catalog" asp-action="Search" class="btn btn-primary mt-2">До каталогу</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="clearModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-body text-center p-4">
                <i class="bi bi-trash3 text-danger mb-3 d-block" style="font-size: 3rem;"></i>
                <h5 class="fw-bold">Очистити список?</h5>
                <p class="text-muted small">Всі книги будуть видалені з ваших уподобань.</p>
            </div>
            <div class="modal-footer border-0 d-flex justify-content-center pb-4 gap-2">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Скасувати</button>
                <form asp-controller="Favorite" asp-action="ClearAll" method="post">
                    <button type="submit" class="btn btn-danger">Так, очистити</button>
                </form>
            </div>
        </div>
    </div>
</div>