@using LNUBookShare.Web.Models
@model BookDetailsViewModel

@{
    ViewData["Title"] = @Model.Title;

    int fullStars = (int)Math.Round(Model.AverageRating);
    int emptyStars = 5 - fullStars;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<style>
    /* стиль для рамки картки*/
    .book-details-card {
        border: 1px solid #ddd;
        border-radius: 25px; 
        padding: 30px;
        background-color: #fff;
    }
    
    /* Стиль для зірочок рейтингу */
    .text-warning {
        color: #ffc107 !important;
    }
    
   
    .breadcrumb-container {
        margin-bottom: 25px;
        margin-top: 20px;
    }
</style>

<div class="container">
    
    <div class="breadcrumb-container d-flex align-items-center gap-2">        
        <a href="@(ViewBag.ReturnUrl ?? Url.Action("Search", "Catalog"))" class="text-decoration-none text-primary fw-bold">Головна</a>
        <i class="bi bi-chevron-right text-primary fs-5"></i>
        <span class="text-primary fw-bold">@Model.Title</span>
    </div>

    <div class="book-details-card shadow-sm">
        <div class="row">
            
            <div class="col-md-4 d-flex align-items-center justify-content-center border-end pe-4">
                @if (Model.Cover != null && !string.IsNullOrEmpty(Model.Cover.ImagePath))
                {
                    <img src="@Model.Cover.ImagePath"
                         alt="Обкладинка"
                         style="height: 100%; width: 100%; object-fit: cover; object-position: center;" />
                }                
                else
                {
                    <div class="bg-light d-flex align-items-center justify-content-center rounded w-100 h-100" style="min-height: 250px; border: 2px dashed #ccc;">
                        <i class="bi bi-image text-secondary" style="font-size: 5rem;"></i>
                    </div>
                }
            </div>

            <div class="col-md-5 ps-4">
                <table class="table table-borderless table-sm m-0">
                    <th>
                        <tr>
                            <td class="text-secondary fw-bold pe-3" style="width: 30%;">Назва:</td>
                            <td class="fw-bold fs-5 text-dark">@Model.Title</td>
                        </tr>
                        <tr>
                            <td class="text-secondary fw-bold pe-3">Автор:</td>
                            <td>@Model.Author</td>
                        </tr>
                        <tr>
                            <td class="text-secondary fw-bold pe-3">Власник:</td>
                            <td>@(Model.Owner?.FirstName ?? "Невідомо") @(Model.Owner?.LastName ?? "")</td>
                        </tr>
                        <tr>
                            <td class="text-secondary fw-bold pe-3">Статус:</td>
                            <td>                                
                                @(Model.Status switch
                                {
                                    "available" => "Доступно",
                                    "reserved" => "Заброньовано",
                                    "borrowed" => "Видано",
                                    _ => Model.Status
                                })                                    
                            </td>
                        </tr>
                        <tr>
                            <td class="text-secondary fw-bold pe-3">Рейтинг:</td>
                            <td>
                                @for (int i = 0; i < fullStars; i++)
                                {
                                    <i class="bi bi-star-fill text-warning"></i>
                                }
                                @for (int i = 0; i < emptyStars; i++)
                                {
                                    <i class="bi bi-star text-warning"></i>
                                }
                                <span class="ms-1 text-secondary">(@Model.AverageRating.ToString("0.0"))</span>
                            </td>
                        </tr>
                        <tr>
                            <td class="text-secondary fw-bold pe-3">Категорія:</td>
                            <td>@(Model.Category?.CategoryName ?? "Невідомо")</td>
                        </tr>
                        <tr>
                            <td class="text-secondary fw-bold pe-3">Мова:</td>
                            <td>@Model.Language</td>
                        </tr>
                        <tr>
                            <td class="text-secondary fw-bold pe-3">Видання:</td>
                            <td>@Model.Publisher</td>
                        </tr>
                        <tr>
                            <td class="text-secondary fw-bold pe-3">ISBN:</td>
                            <td>@Model.Isbn</td>
                        </tr>
                    </>
                </table>
            </div>

            <div class="col-md-3 d-flex flex-column align-items-end justify-content-between">
                <div class="favorite-icon">
                    <partial name="_FavoriteButton" model="(Model.BookId, Model.FavoritedBookIds.Contains(Model.BookId), Context.Request.Path.ToString())" />
                </div>

                <div class="action-buttons d-grid gap-3 w-100 mt-auto" style="max-width: 200px;">
                    @if (Model.Status == "available")
                    {                        
                        <button type="button" class="btn btn-secondary btn-lg fw-bold rounded-pill text-white py-2 shadow-sm disabled" aria-disabled="true">
                            Забронювати
                        </button>
                    }
                    else
                    {                        
                        <button type="button" class="btn btn-light btn-lg fw-bold rounded-pill text-muted py-2 border disabled" aria-disabled="true">
                            Стати в чергу
                        </button>
                    }
                    
                    <a href="#" class="btn btn-secondary btn-lg fw-bold rounded-pill text-white py-2" style="background-color: #6c757d;">
                        Написати власнику
                    </a>
                </div>
            </div>

        </div>
    </div>

</div>