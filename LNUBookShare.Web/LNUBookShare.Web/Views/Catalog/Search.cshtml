@using LNUBookShare.Web.Models
@using LNUBookShare.Domain.Models
@model BookSearchViewModel

@{
    ViewData["Title"] = "Пошук книг";
    var topUsers = ViewBag.TopUsers as IEnumerable<TopUserDto> ?? Enumerable.Empty<TopUserDto>();
}

@section Styles {
    
    <environment include="Development">
        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/modules/bookCard.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/modules/filters.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/modules/leaderboard.css" asp-append-version="true" />
    </environment>
}

<div class="container mt-4">
    <form asp-action="Search" method="get">
        <div class="d-flex mb-4 search-input-group">
            <select name="searchBy" class="form-select filter-select">
                <option value="title" selected="@(Model.SearchBy == "title")">Назва</option>
                <option value="author" selected="@(Model.SearchBy == "author")">Автор</option>
                <option value="isbn" selected="@(Model.SearchBy == "isbn")">ISBN</option>
            </select>

            <div class="position-relative flex-grow-1">
                <i class="bi bi-search position-absolute top-50 translate-middle-y search-icon"></i>
                <input type="text" name="query" id="searchInput"
                       value="@Model.SearchQuery"
                       class="form-control ps-5 py-2 main-search-field"
                       placeholder="Шукати книги..."
                       autocomplete="off" />
            </div>
        </div>

        <div class="row">
            <div class="col-lg-8 pe-lg-4">
                <div class="mb-3">
                    @if (!string.IsNullOrEmpty(Model.SearchQuery))
                    {
                        <h4>Результати для "@Model.SearchQuery"</h4>
                    }
                    else if (ViewBag.IsRecommendation == true)
                    {
                        <h4>Рекомендації для вас</h4>
                    }
                    else
                    {
                        <h4>Усі книги каталогу</h4>
                    }
                    <span class="text-muted small">Знайдено: @Model.TotalCount</span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-3">
                    <div class="d-flex align-items-center gap-2">
                        <select name="sortBy" class="form-select form-select-sm sort-dropdown" onchange="this.form.submit()">
                            <option value="title" selected="@(Model.SortBy == "title")">Назва</option>
                            <option value="author" selected="@(Model.SortBy == "author")">Автор</option>
                            <option value="year" selected="@(Model.SortBy == "year")">Рік видання</option>
                        </select>
                    </div>

                    <div class="d-flex gap-3 align-items-center flex-wrap status-filters">
                        @foreach (var status in new[] { ("all", "Всі"), ("available", "Доступно"), ("borrowed", "Видано"), ("reserved", "Заброньовано") })
                        {
                            <div class="form-check custom-radio">
                                <input class="form-check-input" type="radio" name="statusFilter" id="status-@status.Item1" value="@status.Item1"
                                       checked="@(Model.StatusFilter == status.Item1 || (status.Item1 == "all" && string.IsNullOrEmpty(Model.StatusFilter)))"
                                       onchange="this.form.submit()">
                                <label class="form-check-label" for="status-@status.Item1">@status.Item2</label>
                            </div>
                        }
                    </div>
                </div>

                <div class="book-list">
                    @foreach (var book in Model.Books)
                    {
                        <div class="card mb-3 shadow-sm book-item-card">
                            <div class="row g-0 align-items-center">
                                <div class="col-md-3 book-img-container">
                                    @if (book.Cover != null && !string.IsNullOrEmpty(book.Cover.ImagePath))
                                    {
                                        <img src="@book.Cover.ImagePath" alt="Обкладинка" class="book-main-img" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-image text-secondary display-6"></i>
                                    }
                                </div>
                                <div class="col-md-9 position-relative card-content">
                                    <div class="card-body">
                                        <div class="fav-btn-pos">
                                            <partial name="_FavoriteButton" model="(book.BookId, Model.FavoritedBookIds.Contains(book.BookId), Context.Request.Path + Context.Request.QueryString)" />
                                        </div>
                                        <h5 class="card-title pe-5">
                                            <a asp-controller="Catalog" asp-action="Details" asp-route-id="@book.BookId" class="book-link">
                                                @book.Title
                                            </a>
                                        </h5>
                                        <p class="mb-1 small">Автор: <strong>@book.Author</strong></p>
                                        <p class="mb-1 small">
                                            Власник:
                                            <a asp-controller="OtherProfile" asp-action="Index" asp-route-userId="@book.Owner?.Id" class="owner-link">
                                                @(book.Owner?.FirstName) @(book.Owner?.LastName)
                                            </a>
                                        </p>
                                        <div class="mt-2">
                                            <span class="status-label status-@book.Status">
                                                @(book.Status == "available" ? "Доступно" : book.Status == "reserved" ? "Заброньовано" : "Видано")
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="col-lg-4">
                <h4 class="mb-3">Користувачі місяця</h4>
                <div class="card leaderboard-card">
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            @foreach (var user in topUsers)
                            {
                                <div class="list-group-item d-flex align-items-center border-bottom px-3 py-3">
                                    <div class="user-mini-avatar shadow-sm">
                                        @if (!string.IsNullOrEmpty(user.AvatarPath))
                                        {
                                            <img src="@user.AvatarPath" alt="Аватар" />
                                        }
                                        else
                                        {
                                            <i class="bi bi-person text-secondary"></i>
                                        }
                                    </div>
                                    <div class="ms-3">
                                        <a asp-controller="OtherProfile" asp-action="Index" asp-route-userId="@user.UserId" class="user-leader-link">
                                            @user.FullName
                                        </a>
                                        <span class="badge bg-lnu">@user.AddedBooksCount книг</span>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>