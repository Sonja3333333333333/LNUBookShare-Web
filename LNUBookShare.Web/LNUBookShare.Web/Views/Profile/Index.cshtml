@using LNUBookShare.Web.Models
@model UserProfileViewModel
@{
    ViewData["Title"] = "Кабінет";
    // Отримуємо поточні фільтри з ViewBag, щоб зберігати стан кнопок
    string currentSort = ViewBag.CurrentSort as string ?? "date";
    string currentStatus = ViewBag.CurrentStatus as string ?? "all";
}

@section Styles {
    <environment include="Development,Production">
        <link rel="stylesheet" href="~/css/modules/userCard.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/modules/bookCard.css" asp-append-version="true" />
        <link rel="stylesheet" href="~/css/modules/filters.css" asp-append-version="true" />
    </environment>
}

<div class="container mt-4">
    @* --- ПОВІДОМЛЕННЯ --- *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-pill shadow-sm mb-4">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-pill shadow-sm mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        </div>
    }

    @* --- КАРТКА ПРОФІЛЮ --- *@
    <div class="user-profile-card mb-5">
        <a asp-controller="Profile" asp-action="Edit" class="edit-profile-link" title="Редагувати профіль">
            <i class="bi bi-pencil-square fs-4"></i>
        </a>
        
        <div class="row align-items-center">
            <div class="col-md-3 border-end border-secondary-subtle user-avatar-wrapper">
                @if (!string.IsNullOrEmpty(Model.AvatarPath))
                {
                    <img src="@Model.AvatarPath" alt="Аватар" class="user-avatar-lg" />
                }
                else
                {
                    <div class="user-avatar-placeholder-lg">
                        <i class="bi bi-person" style="font-size: 5rem;"></i>
                    </div>
                }
            </div>
            
            <div class="col-md-9 user-info-section">
                <div class="user-info-item">
                    <span class="user-info-label">Прізвище, Ім'я</span>
                    <div class="user-name-value">@Model.LastName @Model.FirstName</div>
                </div>
                <div class="user-info-item">
                    <span class="user-info-label">Email</span>
                    <div class="user-info-value">@Model.Email</div>
                </div>
                <div class="user-info-item">
                    <span class="user-info-label">Факультет</span>
                    <div class="user-info-value">@Model.FacultyName</div>
                </div>
            </div>
        </div>
    </div>

    <h4 class="text-center fw-bold mb-3">Мої книги</h4>

    @* --- ФОРМА ФІЛЬТРІВ (Тепер працює!) --- *@
    <form asp-action="Index" method="get" class="mb-4">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div class="d-flex align-items-center gap-2">
                <span class="text-muted small">Сортувати:</span>
                <select name="sortBy" class="form-select form-select-sm sort-dropdown" onchange="this.form.submit()">
                    <option value="date" selected="@(currentSort == "date")">Датою додавання</option>
                    <option value="title" selected="@(currentSort == "title")">Назвою</option>
                </select>
            </div>

            <div class="d-flex gap-3 align-items-center status-filters">
                <div class="form-check custom-radio">
                    <input class="form-check-input" type="radio" name="statusFilter" value="all" id="s_all" checked="@(currentStatus == "all")" onchange="this.form.submit()">
                    <label class="form-check-label" for="s_all">Всі</label>
                </div>
                <div class="form-check custom-radio">
                    <input class="form-check-input" type="radio" name="statusFilter" value="available" id="s_avail" checked="@(currentStatus == "available")" onchange="this.form.submit()">
                    <label class="form-check-label" for="s_avail">Доступно</label>
                </div>
                <div class="form-check custom-radio">
                    <input class="form-check-input" type="radio" name="statusFilter" value="borrowed" id="s_borr" checked="@(currentStatus == "borrowed")" onchange="this.form.submit()">
                    <label class="form-check-label" for="s_borr">Видано</label>
                </div>
                <div class="form-check custom-radio">
                    <input class="form-check-input" type="radio" name="statusFilter" value="reserved" id="s_res" checked="@(currentStatus == "reserved")" onchange="this.form.submit()">
                    <label class="form-check-label" for="s_res">Заброньовано</label>
                </div>
            </div>
        </div>
    </form>

    @* --- СПИСОК КНИГ --- *@
    <div class="book-list">
        @if (Model.MyBooks != null && Model.MyBooks.Any())
        {
            @foreach (var book in Model.MyBooks)
            {
                <div class="card mb-3 shadow-sm book-item-card">
                    <div class="row g-0 align-items-center">
                        <div class="col-md-3 book-img-container">
                            @if (book.Cover != null)
                            {
                                <img src="@book.Cover.ImagePath" class="book-main-img" />
                            }
                            else
                            {
                                <i class="bi bi-book text-secondary display-6"></i>
                            }
                        </div>

                        <div class="col-md-9 position-relative">
                            <div class="card-body">
                                @* Кнопки управління з повними data-атрибутами для JS *@
                                <div class="fav-btn-pos d-flex gap-2">
                                    <button type="button" class="btn btn-link p-0 text-secondary edit-book-btn"
                                            data-id="@book.BookId"
                                            data-title="@book.Title"
                                            data-author="@book.Author"
                                            data-year="@book.Year"
                                            data-category="@book.CategoryId"
                                            data-isbn="@book.Isbn"
                                            data-publisher="@book.Publisher"
                                            data-language="@book.Language"
                                            data-bs-toggle="modal" data-bs-target="#editBookModal"
                                            title="Редагувати">
                                        <i class="bi bi-pencil-square fs-4"></i>
                                    </button>
                                    <button type="button" class="btn btn-link p-0 text-danger delete-book-btn"
                                            data-id="@book.BookId"
                                            data-bs-toggle="modal" data-bs-target="#deleteBookModal"
                                            title="Видалити">
                                        <i class="bi bi-trash fs-5"></i>
                                    </button>
                                </div>

                                <h5 class="card-title pe-5">
                                    <a asp-controller="Catalog" asp-action="Details" asp-route-id="@book.BookId" class="book-link">
                                        @book.Title
                                    </a>
                                </h5>
                                <p class="mb-2 small">Автор: <strong>@book.Author</strong></p>
                                
                                <div class="mt-3">
                                    @{
                                        var firstInQueue = book.ReservationQueues?.OrderBy(q => q.CreatedAt).FirstOrDefault();
                                    }

                                    @if (book.Status == "available" || book.Status == "reserved")
                                    {
                                        if (firstInQueue?.User != null)
                                        {
                                            <form asp-action="IssueBook" asp-controller="Profile" method="post" class="m-0">
                                                <input type="hidden" name="bookId" value="@book.BookId" />
                                                <button type="submit" class="btn btn-primary btn-sm">
                                                    <i class="bi bi-check2-circle me-1"></i> Видати @firstInQueue.User.FirstName
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <span class="status-label status-available">Доступна</span>
                                        }
                                    }
                                    else if (book.Status == "borrowed")
                                    {
                                        <form asp-action="ConfirmReturn" asp-controller="Profile" method="post" class="m-0">
                                            <input type="hidden" name="bookId" value="@book.BookId" />
                                            <button type="submit" class="btn btn-primary btn-sm">
                                                <i class="bi bi-arrow-return-left me-1"></i> Підтвердити повернення
                                            </button>
                                        </form>
                                    }
                                </div>
                                <div class="mt-3">
                                    <a asp-controller="Profile" asp-action="Queue" asp-route-bookId="@book.BookId" class="btn btn-light btn-sm">
                                        <i class="bi bi-people me-1"></i> Переглянути чергу
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-journal-x fs-1 d-block mb-3 opacity-25"></i>
                <p>У вас ще немає доданих книг або вони не відповідають фільтру.</p>
            </div>
        }
    </div>

    @* Кнопка додавання книги *@
    <div class="text-center mt-5 mb-5">
        <button class="btn btn-primary rounded-circle shadow-lg d-flex align-items-center justify-content-center mx-auto"
                style="width: 60px; height: 60px; font-size: 30px;"
                data-bs-toggle="modal" data-bs-target="#addBookModal">
            <i class="bi bi-plus-lg text-white"></i>
        </button>
    </div>
</div>

@* --- МОДАЛЬНІ ВІКНА --- *@

@* Додати *@
<div class="modal fade" id="addBookModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow" style="border-radius: 12px;">
            <div class="modal-header bg-light border-bottom">
                <h5 class="modal-title fw-bold">Додати нову книгу</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AddBook" method="post" enctype="multipart/form-data">
                <div class="modal-body p-4">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-muted">Назва *</label>
                            <input name="Title" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-muted">Автор *</label>
                            <input name="Author" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-muted">Видавництво</label>
                            <input name="Publisher" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-muted">Мова</label>
                            <input name="Language" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label small fw-bold text-muted">Рік *</label>
                            <input name="Year" type="number" class="form-control" value="@DateTime.Now.Year" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label small fw-bold text-muted">ISBN</label>
                            <input name="Isbn" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label small fw-bold text-muted">Категорія *</label>
                            @* Використовуємо реальні категорії з бази *@
                            <select name="CategoryId" class="form-select" asp-items="ViewBag.Categories" required>
                                <option value="">Оберіть категорію</option>
                            </select>
                        </div>
                        <div class="col-12 mb-3">
                            <label class="form-label small fw-bold text-muted">Обкладинка</label>
                            <input name="CoverPhoto" type="file" class="form-control" accept="image/*" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Скасувати</button>
                    <button type="submit" class="btn btn-primary px-4">Зберегти</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* Редагувати *@
<div class="modal fade" id="editBookModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow" style="border-radius: 12px;">
            <div class="modal-header bg-light border-bottom">
                <h5 class="modal-title fw-bold">Редагувати книгу</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            @* Додано ID для форми, щоб JS міг змінити action *@
            <form id="editBookForm" asp-action="EditBook" method="post" enctype="multipart/form-data">
                <input type="hidden" name="id" id="edit-id" />
                <div class="modal-body p-4">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-muted">Назва *</label>
                            <input name="Title" id="edit-title" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-muted">Автор *</label>
                            <input name="Author" id="edit-author" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-muted">Видавництво</label>
                            <input name="Publisher" id="edit-publisher" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold text-muted">Мова</label>
                            <input name="Language" id="edit-language" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label small fw-bold text-muted">Рік *</label>
                            <input name="Year" id="edit-year" type="number" class="form-control" required />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label small fw-bold text-muted">ISBN</label>
                            <input name="Isbn" id="edit-isbn" class="form-control" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label small fw-bold text-muted">Категорія *</label>
                            <select name="CategoryId" id="edit-category" class="form-select" asp-items="ViewBag.Categories" required></select>
                        </div>
                        <div class="col-12 mb-3">
                            <label class="form-label small fw-bold text-muted">Нова обкладинка (необов'язково)</label>
                            <input name="CoverPhoto" type="file" class="form-control" accept="image/*" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Скасувати</button>
                    <button type="submit" class="btn btn-primary px-4">Зберегти зміни</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* Видалити *@
<div class="modal fade" id="deleteBookModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-body text-center p-4 pb-2">
                <div class="mb-3 mt-2">
                    <i class="bi bi-trash text-danger d-block" style="font-size: 4rem;"></i>
                </div>
                <h5 class="fw-bold mb-2">Видалити книгу?</h5>
                <p class="text-muted small">Цю дію неможливо скасувати.</p>
            </div>
            <div class="modal-footer border-0 d-flex justify-content-center p-3 pt-0 gap-2">
                <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Ні</button>
                @* Додано ID для форми, щоб JS міг змінити action *@
                <form id="deleteBookForm" asp-action="DeleteBook" method="post">
                    <input type="hidden" name="id" id="delete-id" />
                    <button type="submit" class="btn btn-danger px-4">Так, видалити</button>
                </form>
            </div>
        </div>
    </div>
</div>