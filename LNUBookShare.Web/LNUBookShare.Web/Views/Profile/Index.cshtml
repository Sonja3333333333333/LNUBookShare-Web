@using LNUBookShare.Web.Models
@model UserProfileViewModel
@{
    ViewData["Title"] = "Кабінет";
}

<div class="container mt-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success shadow-sm mb-4" style="border-radius: 8px;">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger shadow-sm mb-4" style="border-radius: 8px;">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        </div>
    }

    <div class="card shadow-sm border-0 mb-5 bg-white" style="border-radius: 12px; border: 1px solid #e0e0e0 !important;">
        <div class="card-body p-4 position-relative">
            <a asp-controller="Profile" asp-action="Edit" class="position-absolute top-0 end-0 mt-3 me-3 text-secondary" title="Редагувати профіль">
                <i class="bi bi-pencil-square fs-4"></i>
            </a>
            <div class="row align-items-center">
                <div class="col-md-3 text-center border-end border-secondary-subtle">
                    @if (!string.IsNullOrEmpty(Model.AvatarPath))
                    {
                        <img src="@Model.AvatarPath" alt="Аватар користувача" class="rounded-circle border shadow-sm" style="width: 140px; height: 140px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="bg-light rounded-circle d-flex align-items-center justify-content-center mx-auto border shadow-sm"
                             style="width: 140px; height: 140px;">
                            <i class="bi bi-person text-secondary" style="font-size: 5rem;"></i>
                        </div>
                    }
                </div>
                <div class="col-md-9 ps-md-4">
                    <div class="mb-2">
                        <small class="text-muted fw-bold">Прізвище, Ім'я</small>
                        <div class="fs-5 fw-bold text-dark">@Model.LastName @Model.FirstName</div>
                    </div>
                    <div class="mb-2">
                        <small class="text-muted fw-bold">Email</small>
                        <div class="text-dark">@Model.Email</div>
                    </div>
                    <div class="mb-2">
                        <small class="text-muted fw-bold">Факультет</small>
                        <div class="text-dark">@Model.FacultyName</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <h4 class="text-center fw-bold mb-4">Мої книги</h4>

    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom border-secondary-subtle">
        <div class="d-flex align-items-center gap-2">
            <span class="text-muted" style="font-size: 0.9rem;">Сортувати за:</span>
            <select class="form-select form-select-sm border-0 bg-light fw-medium" style="width: 150px; cursor: pointer;">
                <option value="date">Датою додавання</option>
                <option value="title">Назвою</option>
            </select>
        </div>

        <div class="d-flex gap-3 align-items-center">
            <div class="form-check custom-radio">
                <input class="form-check-input" type="radio" name="Status" id="s1" checked>
                <label class="form-check-label text-muted" for="s1" style="font-size: 0.9rem;">Видано</label>
            </div>
            <div class="form-check custom-radio">
                <input class="form-check-input" type="radio" name="Status" id="s2">
                <label class="form-check-label text-muted" for="s2" style="font-size: 0.9rem;">Доступно</label>
            </div>
            <div class="form-check custom-radio">
                <input class="form-check-input" type="radio" name="Status" id="s3">
                <label class="form-check-label text-muted" for="s3" style="font-size: 0.9rem;">Заброньовано</label>
            </div>
        </div>
    </div>

    <div class="book-list">
        @if (Model.MyBooks != null && Model.MyBooks.Any())
        {
            @foreach (var book in Model.MyBooks)
            {
                <div class="card mb-3 shadow-sm border-0 bg-white" style="border-radius: 12px; border: 1px solid #e0e0e0 !important; overflow: hidden;">
                    <div class="row g-0 align-items-center">
                        <div class="col-md-3 text-center bg-light d-flex align-items-center justify-content-center p-0" style="height: 160px; border-right: 1px solid #e0e0e0; overflow: hidden;">
                            @if (book.Cover != null)
                            {
                                <img src="@book.Cover.ImagePath" style="height: 100%; width: 100%; object-fit: cover; object-position: center;" />
                            }
                            else
                            {
                                <i class="bi bi-book text-secondary" style="font-size: 3rem;"></i>
                            }
                        </div>

                        <div class="col-md-9 position-relative">
                            <div class="card-body">
                                <div class="position-absolute top-0 end-0 mt-2 me-2 d-flex gap-2">
                                    <button class="btn btn-link p-0 text-secondary edit-book-btn"
                                            data-id="@book.BookId"
                                            data-title="@book.Title"
                                            data-author="@book.Author"
                                            data-publisher="@book.Publisher"
                                            data-year="@book.Year"
                                            data-isbn="@book.Isbn"
                                            data-category="@book.CategoryId"
                                            data-language="@book.Language"
                                            data-bs-toggle="modal" data-bs-target="#editBookModal">
                                        <i class="bi bi-pencil fs-5"></i>
                                    </button>
                                    
                                    <button class="btn btn-link p-0 text-danger delete-book-btn"
                                            data-id="@book.BookId"
                                            data-bs-toggle="modal" data-bs-target="#deleteBookModal"
                                            title="Видалити">
                                        <i class="bi bi-trash fs-5"></i>
                                    </button>
                                </div>

                                <h5 class="card-title pe-5 mb-3">
                                    <a asp-controller="Catalog"
                                           asp-action="Details"
                                           asp-route-id="@book.BookId"
                                           asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)"
                                           class="fw-bold link-dark-hover text-decoration-none text-dark" title="Переглянути деталі">
                                        @book.Title
                                    </a>
                                </h5>
                                <p class="card-text mb-1 text-muted" style="font-size: 0.9rem;">
                                    Автор: <span class="text-dark">@book.Author</span>
                                </p>
                                <p class="card-text mb-0 text-muted" style="font-size: 0.9rem;">
                                    Статус: <span class="text-dark">
                                    @(book.Status?.ToLower() switch
                                    {
                                        "available" => "Доступно",
                                        "reserved" => "Заброньовано",
                                        "borrowed" => "Видано",
                                        _ => book.Status 
                                    })
                                </span>
                            </p>

                                <div class="mt-3">
            
                                    <a asp-controller="Profile" asp-action="Queue" asp-route-bookId="@book.BookId" class="btn btn-sm btn-outline-secondary px-4" style="border-radius: 8px;">
    Переглянути чергу
</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-journal-x fs-1 d-block mb-3"></i>
                <p>У вас ще немає доданих книг.</p>
            </div>
        }
    </div>

    <div class="text-center mt-5 mb-5">
        <button class="btn btn-primary rounded-circle shadow-lg d-flex align-items-center justify-content-center mx-auto"
                style="width: 60px; height: 60px; font-size: 30px; background-color: #0d6efd;"
                data-bs-toggle="modal" data-bs-target="#addBookModal">
            <i class="bi bi-plus-lg text-white"></i>
        </button>
    </div>
</div>

<div class="modal fade" id="addBookModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 12px;">
            <div class="modal-header bg-light border-bottom">
                <h5 class="modal-title fw-bold">Додати нову книгу</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AddBook" method="post" enctype="multipart/form-data">
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <div class="form-label small fw-bold text-muted">Назва</div>
                        <input name="Title" class="form-control border-secondary-subtle" required />
                    </div>
                    <div class="mb-3">
                        <div class="form-label small fw-bold text-muted">Автор</div>
                        <input name="Author" class="form-control border-secondary-subtle" required />
                    </div>
                    <div class="mb-3">
                        <div class="form-label small fw-bold text-muted">Видавництво</div>
                        <input name="Publisher" class="form-control border-secondary-subtle" />
                    </div>
                    <div class="mb-3">
                        <div class="form-label small fw-bold text-muted">ISBN</div>
                        <input name="Isbn" class="form-control border-secondary-subtle" />
                    </div>
                    <div class="mb-3">
                        <div class="form-label small fw-bold text-muted">Мова</div>
                        <input name="Language" class="form-control border-secondary-subtle" />
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <div class="form-label small fw-bold text-muted">Рік</div>
                            <input name="Year" type="number" class="form-control border-secondary-subtle" value="@DateTime.Now.Year" required />
                        </div>
                        <div class="col-6 mb-3">
                            <div class="form-label small fw-bold text-muted">Категорія</div>
                            <select name="CategoryId" class="form-select border-secondary-subtle">
                                <option value="1">Художня</option>
                                <option value="2">Наукова</option>
                                <option value="3">Навчальна</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-label small fw-bold text-muted">Обкладинка</div>
                        <input name="CoverPhoto" type="file" class="form-control border-secondary-subtle" accept="image/*" />
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="submit" class="btn btn-primary px-5 py-2 fw-bold" style="border-radius: 8px;">Зберегти книгу</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="editBookModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 12px;">
            <div class="modal-header bg-light border-bottom">
                <h5 class="modal-title fw-bold">Редагувати книгу</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="editBookForm" asp-action="EditBook" method="post" enctype="multipart/form-data">
                <input type="hidden" name="id" id="edit-id" />
                <div class="modal-body p-4">
                    <div class="mb-3">
                        <div class="form-label small fw-bold text-muted">Назва</div>
                        <input name="Title" id="edit-title" class="form-control border-secondary-subtle" required />
                    </div>
                    <div class="mb-3">
                        <div class="form-label small fw-bold text-muted">Автор</div>
                        <input name="Author" id="edit-author" class="form-control border-secondary-subtle" required />
                    </div>
                    <div class="mb-3">
                        <div class="form-label small fw-bold text-muted">Видавництво</div>
                        <input name="Publisher" id="edit-publisher" class="form-control border-secondary-subtle" />
                    </div>
                    <div class="mb-3">
                        <div class="form-label small fw-bold text-muted">ISBN</div>
                        <input name="Isbn" id="edit-isbn" class="form-control border-secondary-subtle" />
                    </div>
                    <div class="mb-3">
                        <div class="form-label small fw-bold text-muted">Мова</div>
                        <input name="Language" id="edit-language" class="form-control border-secondary-subtle" />
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <div class="form-label small fw-bold text-muted">Рік</div>
                            <input name="Year" id="edit-year" type="number" class="form-control border-secondary-subtle" required />
                        </div>
                        <div class="col-6 mb-3">
                            <div class="form-label small fw-bold text-muted">Категорія</div>
                            <select name="CategoryId" id="edit-category" class="form-select border-secondary-subtle">
                                <option value="1">Художня</option>
                                <option value="2">Наукова</option>
                                <option value="3">Навчальна</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <div class="form-label small fw-bold text-muted">Змінити обкладинку (необов'язково)</div>
                        <input name="CoverPhoto" type="file" class="form-control border-secondary-subtle" accept="image/*" />
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="submit" class="btn btn-primary px-5 py-2 fw-bold" style="border-radius: 8px;">Зберегти зміни</button>
                </div>
            </form>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteBookModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-body text-center p-4 pb-2">
                <div class="mb-3 mt-2">
                    <i class="bi bi-exclamation-circle text-danger d-block" style="font-size: 4rem;"></i>
                </div>
                <h5 class="fw-bold mb-2">Видалити книгу?</h5>
                <p class="text-muted small mb-4">Цю дію неможливо скасувати. Книга назавжди зникне з вашого кабінету.</p>
            </div>
            <div class="modal-footer border-0 d-flex justify-content-center p-3 pt-0 gap-2">
                <button type="button" class="btn btn-light fw-bold px-4" style="border-radius: 12px; background: #f8f9fa;" data-bs-dismiss="modal">Скасувати</button>
                <form id="deleteBookForm" asp-action="DeleteBook" method="post">
                    <button type="submit" class="btn btn-danger fw-bold px-4 shadow-sm" style="border-radius: 12px;">Так, видалити</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.edit-book-btn').forEach(button => {
            button.addEventListener('click', function() {
                const id = this.dataset.id;
                const title = this.dataset.title;
                const author = this.dataset.author;
                const publisher = this.dataset.publisher;
                const year = this.dataset.year;
                const category = this.dataset.category;
                const isbn = this.dataset.isbn; 
                const language = this.dataset.language; 
                document.getElementById('edit-id').value = id;
                document.getElementById('edit-title').value = title;
                document.getElementById('edit-author').value = author;
                document.getElementById('edit-publisher').value = publisher;
                document.getElementById('edit-isbn').value = isbn;
                document.getElementById('edit-year').value = year;
                document.getElementById('edit-category').value = category;
                document.getElementById('edit-language').value = language; 
                
                document.getElementById('editBookForm').action = '/Profile/EditBook/' + id;
            });
        });

        document.querySelectorAll('.delete-book-btn').forEach(button => {
            button.addEventListener('click', function() {
                const id = this.dataset.id;
                document.getElementById('deleteBookForm').action = '/Profile/DeleteBook/' + id;
            });
        });
    </script>
}
}