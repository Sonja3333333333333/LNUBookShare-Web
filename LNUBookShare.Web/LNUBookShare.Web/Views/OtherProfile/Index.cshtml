@using LNUBookShare.Web.Models
@using LNUBookShare.Domain.Entities
@model OtherProfileViewModel

@{
    ViewData["Title"] = "Профіль користувача";
}

@section Styles {
    <link rel="stylesheet" href="~/css/modules/userCard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/bookCard.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/filters.css" asp-append-version="true" />
}

<div class="container mt-4">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-pill shadow-sm mb-4">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-pill shadow-sm mb-4">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
        </div>
    }

    <div class="user-profile-card mb-5">
        <div class="row align-items-center">
            <div class="col-md-3 border-end border-secondary-subtle user-avatar-wrapper flex-column">
                @if (Model.Avatar != null && !string.IsNullOrEmpty(Model.Avatar.ImagePath))
                {
                    <img src="@Model.Avatar.ImagePath" alt="Аватар" class="user-avatar-lg" />
                }
                else
                {
                    <div class="user-avatar-placeholder-lg">
                        <i class="bi bi-person" style="font-size: 5rem;"></i>
                    </div>
                }
                
                <button type="button" class="btn btn-danger btn-sm mt-3" data-bs-toggle="modal" data-bs-target="#reportModal">
                    <i class="bi bi-exclamation-octagon me-1"></i> Поскаржитись
                </button>
            </div>
            
            <div class="col-md-9 user-info-section mt-4 mt-md-0">
                <div class="user-info-item">
                    <span class="user-info-label">Прізвище, Ім'я</span>
                    <div class="user-name-value">@Model.LastName @Model.FirstName</div>
                </div>
                <div class="user-info-item">
                    <span class="user-info-label">Email</span>
                    <div class="user-info-value">@Model.Email</div>
                </div>
                <div class="user-info-item">
                    <span class="user-info-label">Факультет</span>
                    <div class="user-info-value">@Model.Faculty</div>
                </div>
            </div>
        </div>
    </div>

    <h4 class="text-center fw-bold mb-3">Книги користувача</h4>

    <form asp-controller="OtherProfile" asp-action="Index" method="get" class="mb-2">
        <input type="hidden" name="userId" value="@Model.UserId" />
        <div class="d-flex justify-content-between align-items-center mb-1 flex-wrap gap-3">
            <div class="d-flex align-items-center gap-2">
                <select name="sortBy" class="form-select form-select-sm sort-dropdown" onchange="this.form.submit()">
                    <option value="title" selected="@(Model.SortBy == "title")">Назва</option>
                    <option value="author" selected="@(Model.SortBy == "author")">Автор</option>
                    <option value="year" selected="@(Model.SortBy == "year")">Рік видання</option>
                </select>
            </div>

            <div class="d-flex gap-3 align-items-center status-filters">
                <div class="form-check custom-radio">
                    <input class="form-check-input" type="radio" name="statusFilter" id="statusAll" value="all"
                           checked="@(Model.StatusFilter == "all" || string.IsNullOrEmpty(Model.StatusFilter))" onchange="this.form.submit()">
                    <label class="form-check-label" for="statusAll">Всі</label>
                </div>
                <div class="form-check custom-radio">
                    <input class="form-check-input" type="radio" name="statusFilter" id="statusAvail" value="available"
                           checked="@(Model.StatusFilter == "available")" onchange="this.form.submit()">
                    <label class="form-check-label" for="statusAvail">Доступно</label>
                </div>
                <div class="form-check custom-radio">
                    <input class="form-check-input" type="radio" name="statusFilter" id="statusBorrowed" value="borrowed"
                           checked="@(Model.StatusFilter == "borrowed")" onchange="this.form.submit()">
                    <label class="form-check-label" for="statusBorrowed">Видано</label>
                </div>
                <div class="form-check custom-radio">
                    <input class="form-check-input" type="radio" name="statusFilter" id="statusReserved" value="reserved"
                           checked="@(Model.StatusFilter == "reserved")" onchange="this.form.submit()">
                    <label class="form-check-label" for="statusReserved">Заброньовано</label>
                </div>
            </div>
        </div>
    </form>

    <div class="book-list">
        @if (Model.Books != null && Model.Books.Any())
        {
            @foreach (var book in Model.Books)
            {
                <div class="card mb-3 shadow-sm book-item-card">
                    <div class="row g-0 align-items-center">
                        <div class="col-md-3 book-img-container">
                            @if (book.Cover != null && !string.IsNullOrEmpty(book.Cover.ImagePath))
                            {
                                <img src="@book.Cover.ImagePath" alt="Обкладинка" class="book-main-img" />
                            }
                            else
                            {
                                <i class="bi bi-image text-secondary display-6"></i>
                            }
                        </div>
                        <div class="col-md-9 position-relative">
                            <div class="card-body">
                                <div class="fav-btn-pos">
                                    <partial name="_FavoriteButton" model="(book.BookId, Model.FavoritedBookIds.Contains(book.BookId), Context.Request.Path + Context.Request.QueryString)" />
                                </div>
                                <h5 class="card-title pe-5">
                                    <a asp-controller="Catalog" asp-action="Details" asp-route-id="@book.BookId"
                                           asp-route-returnUrl="@(Context.Request.Path + Context.Request.QueryString)"
                                           class="book-link">
                                        @book.Title
                                    </a>
                                </h5>
                                <p class="mb-1 small">Автор: <strong>@book.Author</strong></p>
                                <div class="mt-2">
                                    <span class="status-label @(book.Status switch { "available" => "status-available", "reserved" => "status-reserved", "borrowed" => "status-borrowed", _ => "" })">
                                        @(book.Status switch { "available" => "Доступно", "reserved" => "Заброньовано", "borrowed" => "Видано", _ => book.Status })
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-journal-x fs-1 d-block mb-3 opacity-25"></i>
                <h4 class="fw-bold">Книг не знайдено</h4>
                <p>Цей користувач ще не додав книги або вони не відповідають фільтру.</p>
            </div>
        }
    </div>
</div>

<div class="modal fade" id="reportModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header bg-danger text-white border-0 py-3" style="border-radius: 20px 20px 0 0;">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> Скарга на користувача
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-controller="OtherProfile" asp-action="Report" method="post">
                <div class="modal-body p-4">
                    <input type="hidden" name="reportedUserId" value="@Model.UserId" />
                    
                    <div class="mb-3">
                        <label for="reason" class="form-label small fw-bold text-muted">ПРИЧИНА СКАРГИ</label>
                        <select id="reason" name="reason" class="form-select" required style="border-radius: 10px;">
                            <option value="" disabled selected>Оберіть причину...</option>
                            <option value="Spam">Спам / Фейковий акаунт</option>
                            <option value="Insults">Нецензурна лексика / Образи</option>
                            <option value="Fraud">Шахрайство</option>
                            <option value="BookReturnIssue">Проблеми з поверненням книги</option>
                            <option value="Other">Інше</option>
                        </select>
                    </div>

                    <div class="mb-0">
                        <label for="details" class="form-label small fw-bold text-muted">ДЕТАЛІ (НЕОБОВ'ЯЗКОВО)</label>
                        <textarea class="form-control" id="details" name="details" rows="4"
                                  placeholder="Опишіть ситуацію детальніше..."
                                  style="resize: none; border-radius: 10px;"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 d-flex justify-content-center pb-4 gap-2">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Скасувати</button>
                    <button type="submit" class="btn btn-danger">Надіслати скаргу</button>
                </div>
            </form>
        </div>
    </div>
</div>