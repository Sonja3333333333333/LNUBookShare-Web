@using LNUBookShare.Web.Models
@model ChatViewModel

@{
    ViewData["Title"] = "Месенджер";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

<link rel="stylesheet" href="~/css/chat.css" asp-append-version="true" />

<div class="chat-container">  
    <div class="chat-sidebar">
        <div class="conversation-list">
            @if (Model.Conversations != null && Model.Conversations.Any())
            {
                @foreach (var conv in Model.Conversations)
                {
                    <div class="position-relative conversation-wrapper">
                        <a asp-action="Index" asp-route-receiverId="@conv.InterlocutorId"
                            class="conversation-item @(Model.SelectedUser?.Id == conv.InterlocutorId ? "active" : "")"
                            data-user-id="@conv.InterlocutorId">
                            <div class="d-flex align-items-center">
                                <div class="avatar-placeholder rounded-circle bg-primary d-flex align-items-center justify-content-center text-white me-3" style="width: 48px; height: 48px; flex-shrink: 0;">
                                    @if (!string.IsNullOrEmpty(conv.InterlocutorAvatar))
                                    {
                                        <img src="@conv.InterlocutorAvatar" class="rounded-circle w-100 h-100" style="object-fit: cover;" alt="Avatar" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-person-fill fs-4"></i>
                                    }
                                </div>
                                <div class="w-100 overflow-hidden pr-4">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <h6 class="mb-0 text-truncate fw-bold" style="max-width: 120px;">@conv.InterlocutorName</h6>
                                        <small class="text-muted" style="font-size: 0.75rem;">@conv.LastMessageTime.ToString("HH:mm")</small>
                                    </div>
                                    <p class="mb-0 text-truncate small text-muted">@conv.LastMessage</p>
                                </div>
                            </div>
                        </a>
        
                        <button type="button" 
                                class="btn btn-link text-danger position-absolute delete-conv-btn" 
                                style="top: 50%; right: 10px; transform: translateY(-50%); z-index: 10; display: none;"
                                onclick="confirmDeleteFromSidebar(event, @conv.InterlocutorId)"
                                title="Видалити чат">
                            <i class="bi bi-trash3"></i>
                        </button>
                    </div>
                }
            }
            else
            {
                <div class="text-center mt-5 p-3 text-muted">
                    <i class="bi bi-chat-left-dots fs-1 opacity-25"></i>
                    <p class="mt-2 small">Діалогів ще немає</p>
                </div>
            }
        </div>
    </div>

    <div class="chat-main">
        @if (Model.SelectedUser != null)
        {
            <div class="chat-header shadow-sm">
                <div class="d-flex align-items-center">
                    <div class="avatar-small rounded-circle bg-secondary d-flex align-items-center justify-content-center text-white me-3" style="width: 40px; height: 40px;">
                        @if (!string.IsNullOrEmpty(Model.SelectedUser.Avatar?.ImagePath))
                        {
                            <img src="@Model.SelectedUser.Avatar.ImagePath" class="rounded-circle w-100 h-100" style="object-fit: cover;" alt="User" />
                        }
                        else
                        {
                            <i class="bi bi-person-fill"></i>
                        }
                    </div>
                    <div>
                        <h6 class="mb-0 fw-bold">
                            <a asp-controller="OtherProfile" 
                               asp-action="Index" 
                               asp-route-userId="@Model.SelectedUser.Id" 
                               class="text-dark text-decoration-none link-primary">
                                @Model.SelectedUser.FirstName @Model.SelectedUser.LastName
                            </a>
                        </h6>
                        <small id="statusBadge" class="text-muted" style="font-size: 0.75rem;">
                            <i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i> офлайн
                        </small>
                    </div>
                </div>
            </div>

            <div class="chat-messages" id="chatWindow">
                @foreach (var msg in Model.Messages)
                {
                    var isMine = msg.SenderId == Model.CurrentUserId;
                    <div class="message-bubble @(isMine ? "message-sent" : "message-received")">
                        @msg.Content
                        <span class="message-time">@msg.SentAt.ToString("HH:mm")</span>
                    </div>
                }
            </div>

            <div class="chat-input-area">
                <form asp-action="SendMessage" method="post" class="d-flex gap-2" id="chatForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="receiverId" id="receiverId" value="@Model.SelectedUser.Id" />
                    <input type="text" name="content" id="messageContent" class="form-control rounded-pill border-0 bg-light px-4"
                            placeholder="Введіть повідомлення..." required autocomplete="off" />
                    <button type="submit" class="btn btn-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </form>
            </div>
        }
        else
        {
            <div class="empty-chat">
                <div class="text-center">
                    <i class="bi bi-chat-right-quote" style="font-size: 5rem; opacity: 0.1;"></i>
                    <h5 class="mt-3 fw-bold opacity-50">Оберіть чат</h5>
                    <p class="opacity-50">Почніть спілкування з власником книги</p>
                </div>
            </div>
        }
    </div>
</div>


<div class="modal fade" id="deleteChatModal" tabindex="-1" aria-labelledby="deleteChatModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold" id="deleteChatModalLabel">Видалити діалог?</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-muted">
                Ви впевнені, що хочете видалити цей чат для себе? Ви більше не зможете бачити історію повідомлень, але вона залишиться доступною для вашого співрозмовника. Відновити історію буде неможливо.
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-light rounded-pill px-4" data-bs-dismiss="modal">Скасувати</button>
                <button type="button" id="confirmDeleteBtn" class="btn btn-danger rounded-pill px-4">Видалити назавжди</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>

    <script>
        const chatWindow = document.getElementById("chatWindow");
        const chatForm = document.getElementById("chatForm");
        const messageInput = document.getElementById("messageContent");
        const currentUserId = "@Model.CurrentUserId";
        const selectedUserId = "@Model.SelectedUser?.Id";
        const statusBadge = document.getElementById("statusBadge");

        const scrollToBottom = () => {
            if (chatWindow) chatWindow.scrollTop = chatWindow.scrollHeight;
        };
        scrollToBottom();

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub")
            .build();

        connection.on("ReceiveMessage", function (senderId, content, time) {
            const isMine = senderId == currentUserId;
            const interlocutorId = isMine ? selectedUserId : senderId;
            if (senderId == selectedUserId || senderId == currentUserId) {
                const messageHtml = `
                    <div class="message-bubble ${isMine ? 'message-sent' : 'message-received'}">
                        ${content}
                        <span class="message-time">${time}</span>
                    </div>`;
                chatWindow.insertAdjacentHTML('beforeend', messageHtml);
                scrollToBottom();
            }

            const sidebarItem = document.querySelector(`.conversation-item[data-user-id="${interlocutorId}"]`);
            
            if (sidebarItem) {
                // Якщо діалог вже є в списку – оновлюємо текст і кидаємо нагору
                const lastMsgEl = sidebarItem.querySelector('p.text-muted');
                const timeEl = sidebarItem.querySelector('small.text-muted');
                
                if (lastMsgEl) lastMsgEl.innerText = content;
                if (timeEl) timeEl.innerText = time;
                
                const list = document.querySelector('.conversation-list');
                if (list) list.prepend(sidebarItem); // Магія! Чат стрибає наверх списку
            } else {
                // Якщо це абсолютно новий діалог (ви щойно написали власнику вперше)
                // Робимо швидкий рефреш, щоб сервер підтягнув його аватарку та ім'я в список
                window.location.reload();
            }
        });

        // ОБРОБКА СТАТУСУ
        connection.on("UserStatusChanged", function (userId, isOnline) {
            if (userId == selectedUserId) {
                updateStatusUI(isOnline);
            }
        });

        function updateStatusUI(isOnline) {
            if (!statusBadge) return;
            statusBadge.innerHTML = isOnline 
                ? '<i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i> онлайн' 
                : '<i class="bi bi-circle-fill" style="font-size: 0.5rem;"></i> офлайн';
            statusBadge.className = isOnline ? "text-success" : "text-muted";
        }

        connection.start().then(() => {
            connection.invoke("JoinPrivateChat", currentUserId);
            if (selectedUserId) {
                connection.invoke("IsUserOnline", parseInt(selectedUserId)).then(updateStatusUI);
            }
        });

        // AJAX ВІДПРАВКА
        if (chatForm) {
            chatForm.addEventListener("submit", function (e) {
                e.preventDefault();
                const content = messageInput.value.trim();
                if (!content) return;

                const formData = new FormData(chatForm);
                fetch(chatForm.action, {
                    method: "POST",
                    body: formData,
                    headers: { "X-Requested-With": "XMLHttpRequest" }
                }).then(response => {
                    if (response.ok) {
                        messageInput.value = ""; 
                    } else {
                        alert("Помилка відправки");
                    }
                });
            });
        }

        let userToDelete = null;
        const deleteModal = new bootstrap.Modal(document.getElementById('deleteChatModal'));
        const confirmBtn = document.getElementById('confirmDeleteBtn');        

        // Виклик з бокової панелі
        function confirmDeleteFromSidebar(e, receiverId) {
            e.preventDefault();
            e.stopPropagation();
            userToDelete = receiverId;
            deleteModal.show();
        }

        // Слухач на кнопку "Видалити" в модальному вікні
        confirmBtn.addEventListener('click', function() {
            if (!userToDelete) return;

            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            fetch(`/Chat/DeleteConversation?receiverId=${userToDelete}`, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'RequestVerificationToken': token
                }
            }).then(response => {
                if (response.ok) {
                    deleteModal.hide();
            
                    // Видаляємо з бокової панелі
                    const sidebarItem = document.querySelector(`.conversation-item[data-user-id="${userToDelete}"]`);
                    if (sidebarItem) {
                        const wrapper = sidebarItem.closest('.conversation-wrapper');
                        if (wrapper) wrapper.remove();
                    }

                    // Якщо видалений чат був відкритий — редірект
                    if (window.location.search.includes(`receiverId=${userToDelete}`) || selectedUserId == userToDelete) {
                        window.location.href = '/Chat/Index';
                    }
                } else {
                    alert("Помилка при видаленні");
                }
            }).catch(err => console.error("Error:", err));
        });
    </script>
}