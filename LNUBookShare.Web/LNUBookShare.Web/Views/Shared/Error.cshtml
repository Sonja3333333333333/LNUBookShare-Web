@model ErrorViewModel
@{
    ViewData["Title"] = "Упс! Помилка";
}

<div class="container mt-5">
    <div class="row justify-content-center text-center">
        <div class="col-md-8">
            <div class="card border-0 shadow-lg" style="border-radius: 20px;">
                <div class="card-body p-5">
                    
                    <i class="bi bi-journal-x text-danger mb-4" style="font-size: 6rem;"></i>
                    
                    <h1 class="display-4 fw-bold text-dark mb-3">Упс! Щось пішло не так</h1>
                    
                    <p class="lead text-muted mb-4">
                        Вибачте, але під час обробки вашого запиту сталася непередбачувана помилка.

                    </p>

                    <div class="d-flex justify-content-center gap-3">
                        <a asp-controller="Catalog" asp-action="Search" class="btn btn-primary px-4 py-2" style="border-radius: 10px;">
                            <i class="bi bi-house-door me-2"></i> На головну
                        </a>
                        <a href="javascript:history.back()" class="btn btn-outline-secondary px-4 py-2" style="border-radius: 10px;">
                            <i class="bi bi-arrow-left me-2"></i> Повернутися назад
                        </a>
                    </div>

                    @if (Model.ShowRequestId)
                    {
                        <div class="mt-5 pt-3 border-top text-muted small">
                            <code>Request ID: @Model.RequestId</code>
                            <br />
                            <span class="text-secondary" style="font-size: 0.8rem;">(Повідомте цей код службі підтримки, якщо проблема не зникає)</span>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>