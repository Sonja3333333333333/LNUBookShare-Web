<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LnuBookShare</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/components.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modules/bookCard.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom mb-3">
            <div class="container-fluid">
                <a class="brand-logo me-4" asp-controller="Catalog" asp-action="Search">
                    <i class="bi bi-book-half"></i> LNU<span>BookShare</span>
                </a>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <ul class="navbar-nav nav-main flex-grow-1 px-4 gap-2">
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Catalog" asp-action="Search">Головна</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="GlobalSearch" asp-action="Index">
                                    Глобальний пошук
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Profile" asp-action="Index">Кабінет</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Notification" asp-action="Index">Сповіщення</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="" asp-controller="Chat" asp-action="Index">Чат</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-controller="Favorite" asp-action="Index">
                                    Уподобання
                                </a>
                            </li>
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Admin" asp-action="Users">
                                        Користувачі
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Admin" asp-action="Books">
                                        Книги
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Admin" asp-action="Reviews">
                                        Коментарі
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-dark" asp-controller="Admin" asp-action="Reports">
                                        Скарги
                                    </a>
                                </li>
                                <li>
                                    <a class="nav-link text-dark" asp-controller="Admin" asp-action="Transactions">
                                        Транзакції
                                    </a>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="flex-grow-1"></div>
                    }

                    <ul class="navbar-nav ms-auto px-4 gap-2 align-items-center">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-primary fw-bold">
                                    <i class="bi bi-person-circle me-1"></i> @User.Identity.Name
                                </span>
                            </li>
                            <li class="nav-item">
                                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Вийти</button>
                                </form>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>
    
    <div id="global-loader" class="d-none position-fixed top-50 start-50 translate-middle" style="z-index: 9999;">
        <div class="loader-spinner" style="border-top-color: var(--primary-lnu); width: 3rem; height: 3rem;"></div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <environment include="Development">
        <script src="~/js/site.js" asp-append-version="true"></script>
        <script src="~/js/chat.js" asp-append-version="true"></script>
        <script src="~/js/profile.js" asp-append-version="true"></script>
    </environment>

    <environment exclude="Development">
        <script src="~/js/site.min.js" asp-append-version="true"></script>
    </environment>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>