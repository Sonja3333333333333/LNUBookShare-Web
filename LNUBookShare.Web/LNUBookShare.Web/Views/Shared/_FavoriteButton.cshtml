@model (int BookId, bool IsFavorited, string ReturnUrl)

<div class="favorite-icon">
    <form asp-controller="Favorite" asp-action="Toggle" method="post">
        <input type="hidden" name="bookId" value="@Model.BookId" />
        <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
        <button type="submit" class="btn btn-link p-0 text-decoration-none">
            <i class="bi @(Model.IsFavorited ? "bi-heart-fill text-danger" : "bi-heart text-dark hover-danger") fs-4"></i>
        </button>
    </form>
</div>