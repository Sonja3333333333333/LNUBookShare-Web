@using LNUBookShare.Domain.Entities
@model IEnumerable<Notification>

    @{
    ViewData["Title"] = "Сповіщення";
    }

    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-12 col-md-8">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 class="fw-bold mb-0">Сповіщення</h4>
                    @if (Model != null && Model.Any())
                {
                    <form asp-action="DeleteAll" method="post">
                        <button type="submit" class="btn btn-outline-danger btn-sm">
                            <i class="bi bi-trash me-1"></i> Видалити всі
                        </button>
                    </form>
                }
                </div>

                @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success shadow-sm mb-4" style="border-radius: 8px;">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                </div>
            }
                @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger shadow-sm mb-4" style="border-radius: 8px;">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
                </div>
            }

                @if (Model != null && Model.Any())
            {
                @foreach (var notification in Model)
                {
                <div class="card mb-3 shadow-sm border-0 bg-white"
                     style="border-radius: 12px; border: 1px solid #e0e0e0 !important;">
                    <div class="card-body d-flex justify-content-between align-items-start p-3">
                        <div class="d-flex align-items-start gap-3">
                            <div class="mt-1">
                                <i class="bi bi-bell text-primary fs-5"></i>
                            </div>
                            <div>
                                <p class="mb-1 text-dark">@notification.Message</p>
                                <small class="text-muted">
                                    @notification.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                                </small>
                                @if (notification.Book != null)
                                    {
                                <div class="mt-1">
                                    <a asp-controller="Catalog"
                                       asp-action="Details"
                                       asp-route-id="@notification.BookId"
                                       class="text-primary small text-decoration-none">
                                        <i class="bi bi-book me-1"></i> Переглянути книгу
                                    </a>
                                </div>
                                    }
                            </div>
                        </div>

                        <form asp-action="Delete" method="post" class="ms-3">
                            <input type="hidden" name="id" value="@notification.Id" />
                            <button type="submit"
                                    class="btn btn-link p-0 text-danger"
                                    title="Видалити сповіщення">
                                <i class="bi bi-x-lg fs-5"></i>
                            </button>
                        </form>
                    </div>
                </div>
                }
            }
            else
            {
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-bell-slash fs-1 d-block mb-3"></i>
                    <p>Сповіщень немає.</p>
                </div>
            }

            </div>
        </div>
    </div>
