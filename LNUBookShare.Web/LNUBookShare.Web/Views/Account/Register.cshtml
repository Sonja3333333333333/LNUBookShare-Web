@model LNUBookShare.Web.Models.RegisterViewModel

@section Styles {
    <environment include="Development">
        <link rel="stylesheet" href="~/css/modules/auth.css" asp-append-version="true" />
    </environment>
}

<div class="auth-container mt-5">    
    <div class="auth-card">
        <div class="auth-header">
            <h2>Створення акаунту</h2>
            <p class="text-muted">Приєднуйтесь до спільноти LNU BookShare</p>
        </div>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="FirstName" class="form-label">Ім'я</label>
                    <input asp-for="FirstName" class="form-control" />
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="LastName" class="form-label">Прізвище</label>
                    <input asp-for="LastName" class="form-control" />
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Факультет</label>
                <select asp-for="FacultyId" class="form-select" asp-items="ViewBag.Faculties">
                    <option value="">-- Оберіть факультет --</option>
                </select>
                <span asp-validation-for="FacultyId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Електронна пошта (@@lnu.edu.ua)</label>
                <input asp-for="Email" class="form-control" placeholder="example@@lnu.edu.ua" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Password" class="form-label">Пароль</label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="col-md-6 mb-4">
                    <label asp-for="ConfirmPassword" class="form-label">Підтвердження</label>
                    <input asp-for="ConfirmPassword" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
            </div>

            <button type="submit" class="btn btn-auth w-100" id="submitBtn">
                <span class="btn-text">Зареєструватися</span>
                <span class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
            </button>
        </form>
        <div class="mt-4 text-center">
            <p class="text-muted">Вже маєте акаунт? <a asp-controller="Account" asp-action="Login" class="link-custom">Увійти</a></p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        setupButtonSpinner('registerForm', 'submitBtn');
    </script>
}