@model LNUBookShare.Web.Models.LoginViewModel

@{
    ViewData["Title"] = "Вхід в систему";
}

@section Styles {
    <link rel="stylesheet" href="~/css/modules/auth.css" asp-append-version="true" />
}

<div class="auth-container mt-5">   
    <div class="auth-card">
        <div class="auth-header">
            <h2>Вхід</h2>
            <p class="text-muted">Вітаємо знову в LNU BookShare</p>
        </div>

                @* --- БЛОК ПОВІДОМЛЕНЬ (Успіх або Помилка) --- *@
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-controller="Account" asp-action="Login" asp-route-returnurl="@ViewData["ReturnUrl"]" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Пошта (@@lnu.edu.ua)</label>
                        <input asp-for="Email" class="form-control" placeholder="ivan.ivanov@lnu.edu.ua" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Пароль</label>
                        <input asp-for="Password" class="form-control" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="mb-3 form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label">Запам'ятати мене</label>
                    </div>


                    <button type="submit" class="btn btn-auth" id="loginBtn">
                        <span class="btn-text">Увійти</span>
                        <span class="spinner-border spinner-border-sm d-none" role="status" aria-hidden="true"></span>
                    </button>
                </form>

                <div class="mt-3 text-center">
                    <p>Ще немає акаунту? <a asp-controller="Account" asp-action="Register">Зареєструватися</a></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        setupButtonSpinner('loginForm', 'loginBtn');
    </script>
}